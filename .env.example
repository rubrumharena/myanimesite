# For Google OAuth, add your client secret JSON file from Google Cloud separately.
# Example: client_secret_xxx.json

# Django settings
DEBUG=True # local development
SECRET_KEY=your_secret_key
DOMAIN_NAME=http://localhost:8000

# Database
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Kinopoisk API
KINOPOISK_TOKEN=your_token

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SECRET=your_elasticsearch_secret
ELASTICSEARCH_USER=your_elasticsearch_user

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_host_user
EMAIL_HOST_PASSWORD=your_email_host_password
EMAIL_USE_TLS=True

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Stripe
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_ACCOUNT_ID=your_stripe_account_id
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret